{
  "mcpServers": {
    "fb-ads-mcp-server": {
      "command": "npx",
      "args": ["-y", "fb-ads-mcp-server"],
      "env": {
        "FB_ACCESS_TOKEN": "${FB_ACCESS_TOKEN}",
        "FB_APP_ID": "${FB_APP_ID}",
        "FB_APP_SECRET": "${FB_APP_SECRET}",
        "FB_AD_ACCOUNT_ID": "${FB_AD_ACCOUNT_ID}"
      }
    }
  }
}
